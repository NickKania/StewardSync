{
  "name": "steward-sync",
  "version": "0.0.1",
  "description": "Unified application for reviewing racing steward reports",
  "scripts": {
    "ng": "ng",
    "start": "./scripts/generate-runtime-config-local.sh && ng serve",
    "start:local": "./scripts/generate-runtime-config-local.sh && ng serve --configuration local",
    "start:staging": "dotenv -e .env.staging -- ./scripts/generate-env.sh && ng serve --configuration staging",
    "build": "ng build",
    "build:prod": "./scripts/build-prod.sh",
    "detect:convex-url": "./scripts/detect-convex-url.sh",
    "build:docker": "ng build",
    "docker:build:fast": "./scripts/build-docker-fast.sh",
    "build:fast": "ng build --configuration=production",
    "build:local": "ng build --configuration local",
    "build:staging": "./scripts/generate-env.sh && ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "concurrently \"bun x convex dev\" \"ng serve\"",
    "dev:local": "concurrently \"docker compose -f docker-compose.local.yml up backend dashboard\" \"ng serve --configuration local\"",
    "dev:staging": "concurrently \"dotenv -e .env.staging -- sh -c 'unset CONVEX_SELF_HOSTED_ADMIN_KEY && bun x convex dev'\" \"dotenv -e .env.staging -- ng serve --configuration staging\"",
    "dev:docker": "docker compose up",
    "dev:docker:build": "docker compose up --build",
    "convex:dev": "bun x convex dev",
    "convex:deploy": "bun x convex deploy",
    "convex:staging:deploy": "dotenv -e .env.staging -- sh -c 'unset CONVEX_SELF_HOSTED_ADMIN_KEY && bun x convex deploy'",
    "convex:local:start": "docker compose -f docker-compose.local.yml up -d backend dashboard",
    "convex:local:stop": "docker compose -f docker-compose.local.yml down",
    "convex:local:logs": "docker compose -f docker-compose.local.yml logs -f backend dashboard",
    "convex:local:push": "CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210 bun x convex deploy --admin-key $CONVEX_SELF_HOSTED_ADMIN_KEY",
    "convex:local:admin-key": "docker compose -f docker-compose.local.yml exec backend ./generate_admin_key.sh",
    "docker:build": "docker compose build",
    "docker:build:local": "./scripts/build-images.sh",
    "docker:push": "./scripts/push-images.sh",
    "docker:tag:latest": "./scripts/tag-latest.sh",
    "docker:up": "docker compose up",
    "docker:up:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@convex-dev/sharded-counter": "^0.2.0",
    "convex": "^1.10.0",
    "date-fns": "^3.6.0",
    "discord.js": "^14.25.1",
    "html-to-image": "^1.11.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/node": "^20.19.28",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.4.0"
  }
}
