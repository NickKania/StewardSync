# Railway Dockerfile - uses pre-built image from GHCR
# This avoids timeout issues by not building Angular on Railway

# Use the image from GitHub Container Registry
# Railway will substitute RAILWAY_GH_REPO with the actual repo path
ARG RAILWAY_GH_REPO
FROM ghcr.io/${RAILWAY_GH_REPO}:latest

# Runtime environment variables will be injected by Railway
# The entrypoint.sh handles runtime config substitution
