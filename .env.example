# Convex Cloud URL (get this from dashboard.convex.dev)
PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Development settings
PUBLIC_ENABLE_DEV_LOGIN=false

# Optional Discord settings
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional race ban review Discord notifications
# Must be a guild text channel ID (forum channels are not supported).
DISCORD_BOT_TOKEN=
DISCORD_RACE_REVIEW_CHANNEL_ID=

# Frontend port (optional)
APP_PORT=4200
