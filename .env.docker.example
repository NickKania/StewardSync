# Your Docker Hub username for pulling/pushing images
DOCKER_USERNAME=your-dockerhub-username

# Required for secure Convex self-hosting. Generate with:
# openssl rand -hex 32
CONVEX_INSTANCE_SECRET=replace-with-random-secret

# Optional instance label used in generated keys.
CONVEX_INSTANCE_NAME=stewardsync-local

# Public origins used by Convex backend metadata.
# For local use the defaults below; for cloud use your public URLs.
CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211

# URL injected into the frontend at container startup.
PUBLIC_CONVEX_URL=http://localhost:3210
# Disable developer-only login page in deployed environments.
PUBLIC_ENABLE_DEV_LOGIN=false

# Convex dashboard target URL.
NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210

# Optional published host ports.
APP_PORT=4200
CONVEX_API_PORT=3210
CONVEX_ACTIONS_PORT=3211
CONVEX_DASHBOARD_PORT=6791
