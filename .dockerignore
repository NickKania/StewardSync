# Git files
.git
.gitignore
.github

# Environment files
.env
.env.*

# IDE and editor files
.vscode
.idea
.angular
.opencode
.claude

# Build output (except dist/steward-sync which is needed for fast builds)
.angular
.cache
# Allow dist/steward-sync for fast Docker builds
dist
!dist/steward-sync

# Dependencies (copied separately via bun install)
node_modules

# Logs
npm-debug.log
yarn-error.log
bun.lockb
*.log

# Documentation
README.md
LICENSE
AGENTS.md
plan.md
*.md
!package.json

# Docker files (don't copy into container)
Dockerfile
docker-compose*.yml
docker-compose*.yaml
compose*.yml
compose*.yaml
.dockerignore

# Test files
*.spec.ts
karma.conf.js
tsconfig.spec.json
test/
tests/
*.test.ts

# CI/CD
.github/
.gitlab-ci.yml

# Misc
.DS_Store
Thumbs.db
coverage/

# Convex files - not needed for frontend build
convex/

# Temporary files
.tmp
*.tmp
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Additional optimization: Exclude unnecessary source maps and test files from build context
coverage/
*.map
e2e/
