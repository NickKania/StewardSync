@using StewardSync.Models
@using StewardSync.Services
@using StewardSync.Services.Authentication
@inject UserService UserService
@inject AuthenticationService AuthService
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">StewardSync</a>
        @if (AuthService.IsAuthenticated)
        {
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">
                    <i class="bi bi-person-circle"></i> @AuthService.CurrentUser!.UserName (@AuthService.CurrentUser.Role.RoleName)
                </span>
                <a class="nav-link" href="/logout">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        }
        else
        {
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/login">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </a>
            </div>
        }
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler"/>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    @if (AuthService.IsAuthenticated)
    {
        <nav class="nav flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door-fill me-2" aria-hidden="true"></i> Home
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="report-incident">
                    <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i> Report Incident
                </NavLink>
            </div>

            @if (AuthService.CanUserReviewReport())
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="review-report">
                        <i class="bi bi-clipboard-check-fill me-2" aria-hidden="true"></i> Review Report
                    </NavLink>
                </div>
            }

            @if (AuthService.CanUserFinalizeReport())
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="finalize-report">
                        <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i> Finalize Report
                    </NavLink>
                </div>
            }

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="reports">
                    <i class="bi bi-list-ul me-2" aria-hidden="true"></i> View Reports
                </NavLink>
            </div>
        </nav>
    }
    else
    {
        <nav class="nav flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">
                    <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i> Login
                </NavLink>
            </div>
        </nav>
    }
</div>

