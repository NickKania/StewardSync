@page "/review-report"
@using StewardSync.Models
@using StewardSync.Services
@using StewardSync.Services.Authentication
@inject ReportService ReportService
@inject ReviewService ReviewService
@inject UserService UserService
@inject AuthenticationService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Review Report - StewardSync</PageTitle>

<div class="content fade-in">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center">
                <h1 class="display-5 fw-bold text-gradient mb-3">Review Report</h1>
                <p class="lead text-muted">Review and provide feedback on incident reports</p>
            </div>
        </div>
    </div>

@if (selectedReport == null)
{
    <div class="form-container form-enhanced">
        <div class="form-section-title">
            <i class="bi bi-clipboard-check-fill"></i>
            Select a Report to Review (@unfinalizedReports.Count available)
        </div>
        
        @if (unfinalizedReports.Any())
        {
            <div class="reports-list">
                @foreach (var report in unfinalizedReports)
                {
                    <div class="report-select-card" @onclick="() => SelectReport(report)">
                        <div class="report-select-header">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-primary fs-6">#@report.ReportId</span>
                                    <h6 class="mt-2 mb-1">Incident Report</h6>
                                </div>
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>@report.ReportDate:yyyy-MM-dd HH:mm
                                </small>
                            </div>
                        </div>
                        <div class="report-select-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <i class="bi bi-person-up text-primary me-2"></i>
                                        <strong>Reporting:</strong> @report.ReportingDriver.DriverName
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <i class="bi bi-person-down text-warning me-2"></i>
                                        <strong>Reported:</strong> @report.ReportedDriver.DriverName
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <i class="bi bi-geo-alt text-info me-2"></i>
                                        <strong>@report.Event.Series</strong>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <i class="bi bi-flag text-secondary me-2"></i>
                                        Race @report.Race.RaceNumber - Turn @report.Turn
                                    </div>
                                </div>
                            </div>
                            @if (report.Reviews.Any())
                            {
                                <div class="mt-2">
                                    <span class="badge bg-info">
                                        <i class="bi bi-chat-dots me-1"></i>@report.Reviews.Count Review(s)
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-clipboard-x display-1 text-muted"></i>
                <h3 class="mt-3 text-muted">No Reports to Review</h3>
                <p class="text-muted">All reports have been reviewed or there are no unfinalized reports.</p>
                <a href="/reports" class="btn btn-primary">
                    <i class="bi bi-list-ul me-2"></i>View All Reports
                </a>
            </div>
        }
    </div>
}
else
{
    <div class="row">
        <!-- Incident Details Column -->
        <div class="col-lg-6">
            <div class="form-container form-enhanced">
                <div class="form-section-title">
                    <i class="bi bi-info-circle-fill"></i>
                    Incident Details
                </div>
                
                <div class="row g-3">
                    <div class="col-6">
                        <div class="info-card">
                            <small class="text-muted d-block">Report ID</small>
                            <strong class="text-primary">#@selectedReport.ReportId</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="info-card">
                            <small class="text-muted d-block">Date & Time</small>
                            <strong>@selectedReport.ReportDate:yyyy-MM-dd HH:mm</strong>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="info-card">
                            <small class="text-muted d-block">Event</small>
                            <strong>@selectedReport.Event.Series - @selectedReport.Event.TrackName</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="info-card">
                            <small class="text-muted d-block">Race</small>
                            <span class="badge bg-info">Race @selectedReport.Race.RaceNumber</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="info-card">
                            <small class="text-muted d-block">Turn</small>
                            <span class="badge bg-secondary">Turn @selectedReport.Turn</span>
                        </div>
                    </div>
                </div>

                <div class="form-section mt-4">
                    <div class="form-section-title">
                        <i class="bi bi-people-fill"></i>
                        Drivers Involved
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="driver-card">
                                <small class="text-muted d-block">Reporting Driver</small>
                                <div class="d-flex align-items-center">
                                    <span class="driver-number-large">@selectedReport.ReportingDriver.DriverNumber</span>
                                    <div>
                                        <strong>@selectedReport.ReportingDriver.DriverName</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="driver-card reported">
                                <small class="text-muted d-block">Reported Driver</small>
                                <div class="d-flex align-items-center">
                                    <span class="driver-number-large">@selectedReport.ReportedDriver.DriverNumber</span>
                                    <div>
                                        <strong>@selectedReport.ReportedDriver.DriverName</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section mt-4">
                    <div class="form-section-title">
                        <i class="bi bi-file-text-fill"></i>
                        Incident Description
                    </div>
                     @if (!string.IsNullOrEmpty(selectedReport.VideoUrl))
                     {
                         <div class="mb-3">
                             <a href="@selectedReport.VideoUrl" target="_blank" class="btn btn-outline-primary w-100">
                                 <i class="bi bi-play-circle me-2"></i>Watch Video Evidence
                             </a>
                         </div>
                     }
                    <div class="description-box">
                        @selectedReport.Description
                    </div>
                </div>
            </div>
        </div>

        <!-- Review Form Column -->
        <div class="col-lg-6">
            <div class="form-container form-enhanced">
                <div class="form-section-title">
                    <i class="bi bi-clipboard-check-fill"></i>
                    Submit Your Review
                </div>
                
                <EditForm Model="@reviewModel" OnValidSubmit="HandleValidSubmit" FormName="reviewReportForm" class="@formLoadingClass">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="form-section">
                        <div class="form-group">
                            <label class="form-label required">Analysis</label>
                            <InputTextArea class="form-control form-control-lg" @bind-Value="reviewModel.Analysis" 
                                         rows="6" placeholder="Provide your analysis of what happened..." />
                            <div class="textarea-character-count">
                                <span>@reviewModel.Analysis?.Length ?? 0</span> / 2000 characters
                            </div>
                            <ValidationMessage For="@(() => reviewModel.Analysis)" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Notes</label>
                            <InputTextArea class="form-control" @bind-Value="reviewModel.Notes" 
                                         rows="4" placeholder="Additional notes, observations, or recommendations..." />
                            <div class="textarea-character-count">
                                <span>@reviewModel.Notes?.Length ?? 0</span> / 1000 characters
                            </div>
                            <ValidationMessage For="@(() => reviewModel.Notes)" />
                        </div>
                    </div>

                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Review Guidelines:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Be objective and factual in your assessment</li>
                            <li>Consider all available information</li>
                            <li>Provide clear reasoning for your conclusions</li>
                            <li>Include any relevant rules or regulations</li>
                        </ul>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-secondary" @onclick="HandleCancel" disabled="@isSubmitting">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Submitting Review...</span>
                            }
                            else
                            {
                                <i class="bi bi-send-fill me-2"></i>
                                <span>Submit Review</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    @if (selectedReport.Reviews.Any())
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="form-container form-enhanced">
                    <div class="form-section-title">
                        <i class="bi bi-people-fill"></i>
                        Previous Reviews (@selectedReport.Reviews.Count)
                    </div>
                    
                    <div class="reviews-container">
                        @foreach (var review in selectedReport.Reviews)
                        {
                            <div class="review-card">
                                <div class="review-header">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi bi-person-circle me-2"></i>
                                            <strong>@review.User.UserName</strong>
                                            <span class="badge bg-info ms-2">@review.User.Role.RoleName</span>
                                        </div>
                                        <small class="text-muted">@review.ReviewDate:yyyy-MM-dd HH:mm</small>
                                    </div>
                                </div>
                                <div class="review-body">
                                    <div class="mb-3">
                                        <strong>Analysis:</strong>
                                        <p class="mb-0 mt-1">@review.Analysis</p>
                                    </div>
                                    @if (!string.IsNullOrEmpty(review.Notes))
                                    {
                                        <div>
                                            <strong>Notes:</strong>
                                            <p class="mb-0 mt-1">@review.Notes</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" role="alert">
        @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3" role="alert">
        @successMessage
    </div>
}

@code {
    private Report? selectedReport;
    private List<Report> unfinalizedReports = new();
    private Review reviewModel = new Review();
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? successMessage;
    private string formLoadingClass = "";


    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadUnfinalizedReports();
    }

    private async Task LoadUnfinalizedReports()
    {
        try
        {
            unfinalizedReports = await ReportService.GetUnfinalizedReportsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading reports: {ex.Message}";
        }
    }

    private async Task SelectReport(Report report)
    {
        try
        {
            selectedReport = await ReportService.GetReportByIdAsync(report.ReportId);

            if (selectedReport != null)
            {
                // Initialize review model
                reviewModel = new Review
                {
                    ReportId = selectedReport.ReportId,
                    UserId = AuthService.CurrentUser!.UserId,
                    Analysis = selectedReport.Description // Pre-populate with original description
                };

                // Clear messages
                errorMessage = null;
                successMessage = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading report details: {ex.Message}";
        }
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting || selectedReport == null) return;

        isSubmitting = true;
        formLoadingClass = "form-loading";
        errorMessage = null;
        successMessage = null;

        try
        {
            await ReviewService.CreateReviewAsync(reviewModel);
            successMessage = "Review submitted successfully!";

            // Reload selected report to show new review
            await SelectReport(selectedReport);

            // Reload unfinalized reports list
            await LoadUnfinalizedReports();

            // Clear form
            reviewModel = new Review
            {
                ReportId = selectedReport.ReportId,
                UserId = AuthService.CurrentUser!.UserId
            };
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            formLoadingClass = "";
        }
    }

    private void HandleCancel()
    {
        selectedReport = null;
        reviewModel = new Review();
        errorMessage = null;
        successMessage = null;
    }
}
</div>
