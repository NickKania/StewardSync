@page "/report-incident"
@using StewardSync.Models
@using StewardSync.Services
@using StewardSync.Services.Authentication
@inject ReportService ReportService
@inject AuthenticationService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Report Incident</PageTitle>

<h3>Report Incident</h3>

<EditForm Model="@reportModel" OnValidSubmit="HandleValidSubmit" FormName="reportIncidentForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group mb-3">
        <label class="form-label">Reporting Driver</label>
        <InputSelect class="form-control" @bind-Value="reportModel.ReportingDriverId">
            <option value="">Select Reporting Driver</option>
            @foreach (var driver in drivers)
            {
                <option value="@driver.DriverId">@driver.DriverNumber - @driver.DriverName</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => reportModel.ReportingDriverId)" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Reported Driver</label>
        <InputSelect class="form-control" @bind-Value="reportModel.ReportedDriverId">
            <option value="">Select Reported Driver</option>
            @foreach (var driver in drivers)
            {
                <option value="@driver.DriverId">@driver.DriverNumber - @driver.DriverName</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => reportModel.ReportedDriverId)" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Event</label>
        <InputSelect class="form-control" @bind-Value="reportModel.EventId" @onchange="HandleEventChange">
            <option value="">Select Event</option>
            @foreach (var evt in events)
            {
                <option value="@evt.EventId">@evt.Series - @evt.EventNumber - @evt.TrackName (@evt.EventDate:yyyy-MM-dd)</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => reportModel.EventId)" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Race</label>
        <InputSelect class="form-control" @bind-Value="reportModel.RaceId" disabled="@racesDisabled">
            <option value="">Select Race</option>
            @foreach (var race in races)
            {
                <option value="@race.RaceId">Race @race.RaceNumber</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => reportModel.RaceId)" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Turn</label>
        <InputNumber class="form-control" @bind-Value="reportModel.Turn" />
        <ValidationMessage For="@(() => reportModel.Turn)" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Incident Description</label>
        <InputTextArea class="form-control" @bind-Value="reportModel.Description" rows="5" />
        <ValidationMessage For="@(() => reportModel.Description)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
        @if (isSubmitting)
        {
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <span class="ms-2">Submitting...</span>
        }
        else
        {
            <span>Submit Report</span>
        }
    </button>

    <button type="button" class="btn btn-secondary ms-2" @onclick="HandleCancel">Cancel</button>
</EditForm>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" role="alert">
        @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3" role="alert">
        @successMessage
    </div>
}

@code {
    private Report reportModel = new Report();
    private List<Driver> drivers = new();
    private List<Event> events = new();
    private List<Race> races = new();
    private bool isSubmitting = false;
    private bool racesDisabled = true;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            drivers = await ReportService.GetAllDriversAsync();
            events = await ReportService.GetAllEventsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private async Task HandleEventChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int eventId) && eventId > 0)
        {
            try
            {
                races = await ReportService.GetRacesByEventIdAsync(eventId);
                racesDisabled = false;
                reportModel.RaceId = 0; // Reset race selection
            }
            catch (Exception ex)
            {
                errorMessage = $"Error loading races: {ex.Message}";
                racesDisabled = true;
            }
        }
        else
        {
            races = new List<Race>();
            racesDisabled = true;
            reportModel.RaceId = 0;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var createdReport = await ReportService.CreateReportAsync(reportModel);
            successMessage = "Report submitted successfully!";

            // Reset form after successful submission
            reportModel = new Report();
            races = new List<Race>();
            racesDisabled = true;

            // Navigate to home after a short delay
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/");
    }
}
