@page "/"
@using StewardSync.Models
@using StewardSync.Services
@using StewardSync.Services.Authentication
@inject ReportService ReportService
@inject ReviewService ReviewService
@inject AuthenticationService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard - StewardSync</PageTitle>

<div class="content fade-in">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center">
                <h1 class="display-4 fw-bold text-gradient mb-3">StewardSync Dashboard</h1>
                <p class="lead text-muted">Unified Racing Steward Reports Management System</p>
                <div class="d-flex justify-content-center align-items-center gap-3">
                    <span class="badge bg-primary bg-gradient px-3 py-2">
                        <i class="bi bi-person-circle me-2"></i>@AuthService.CurrentUser!.UserName
                    </span>
                    <span class="badge bg-info bg-gradient px-3 py-2">
                        <i class="bi bi-shield-check me-2"></i>@AuthService.CurrentUser.Role.RoleName
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="dashboard-card bg-primary">
                <i class="bi bi-file-earmark-text display-6 mb-3"></i>
                <h2>@totalReports</h2>
                <p>Total Reports</p>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="dashboard-card bg-warning">
                <i class="bi bi-exclamation-triangle display-6 mb-3"></i>
                <h2>@openReports</h2>
                <p>Open Reports</p>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="dashboard-card bg-success">
                <i class="bi bi-check-circle display-6 mb-3"></i>
                <h2>@finalizedReports</h2>
                <p>Finalized Reports</p>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="dashboard-card bg-info">
                <i class="bi bi-clipboard-check display-6 mb-3"></i>
                <h2>@totalReviews</h2>
                <p>Total Reviews</p>
            </div>
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row">
        <!-- Recent Reports Section -->
        <div class="col-lg-7 mb-4">
            <div class="form-container form-enhanced">
                <div class="form-section-title">
                    <i class="bi bi-clock-history"></i>
                    Recent Reports
                </div>

                @if (recentReports.Any())
                {
                    <div class="list-group">
                        @foreach (var report in recentReports.Take(5))
                        {
                            <div class="list-group-item list-group-item-action" onclick="window.location.href='/reports'">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 fw-bold">
                                            <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                                            Report #@report.ReportId
                                        </h6>
                                        <p class="mb-2">
                                            <span class="badge bg-info me-2">@report.ReportingDriver.DriverName</span>
                                            reported
                                            <span class="badge bg-warning ms-2">@report.ReportedDriver.DriverName</span>
                                        </p>
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            <small class="text-muted">
                                                <i class="bi bi-geo-alt me-1"></i>@report.Event.Series
                                            </small>
                                            <small class="text-muted">
                                                <i class="bi bi-flag me-1"></i>Race @report.Race.RaceNumber
                                            </small>
                                            <small class="text-muted">
                                                <i class="bi bi-signpost-2 me-1"></i>Turn @report.Turn
                                            </small>
                                            @if (report.Status == ReportStatus.DecisionReached || report.Status == ReportStatus.Closed)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle me-1"></i>@report.Status
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">
                                                    <i class="bi bi-clock me-1"></i>@report.Status
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-nowrap ms-3">
                                        <i class="bi bi-calendar me-1"></i>@report.ReportDate:yyyy-MM-dd
                                    </small>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="text-center mt-3">
                        <a href="/reports" class="btn btn-primary">
                            <i class="bi bi-list-ul me-2"></i>View All Reports
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-inbox display-4 text-muted"></i>
                        <p class="text-muted mt-3">No reports found.</p>
                        <a href="/report-incident" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Create First Report
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Quick Actions Section -->
        <div class="col-lg-5 mb-4">
            <div class="form-container form-enhanced">
                <div class="form-section-title">
                    <i class="bi bi-lightning-fill"></i>
                    Quick Actions
                </div>

                <div class="d-grid gap-3">
                    <a href="/report-incident" class="btn btn-primary btn-lg">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Report New Incident
                    </a>

                    @if (canReviewReports)
                    {
                        <a href="/review-report" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-clipboard-check-fill me-2"></i>
                            Review Reports
                        </a>
                    }

                    @if (canFinalizeReports)
                    {
                        <a href="/finalize-report" class="btn btn-outline-danger btn-lg">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            Finalize Reports
                        </a>
                    }

                    <a href="/reports" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-list-ul me-2"></i>
                        View All Reports
                    </a>
                </div>
            </div>

            <!-- System Info Card -->
            <div class="form-container form-enhanced mt-4">
                <div class="form-section-title">
                    <i class="bi bi-info-circle-fill"></i>
                    System Information
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded">
                            <small class="text-muted d-block">Application</small>
                            <strong>StewardSync</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded">
                            <small class="text-muted d-block">Version</small>
                            <strong>1.0.0</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded">
                            <small class="text-muted d-block">Purpose</small>
                            <strong>Racing Steward Mgmt</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded">
                            <small class="text-muted d-block">Status</small>
                            <strong class="text-success">Online</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-overlay">
        <div class="loading-spinner"></div>
    </div>
}

@code {
    private List<Report> allReports = new();
    private List<Report> recentReports = new();
    private List<Review> allReviews = new();
    private int totalReports = 0;
    private int openReports = 0;
    private int finalizedReports = 0;
    private int totalReviews = 0;
    private bool isLoading = true;
    private bool canReviewReports = false;
    private bool canFinalizeReports = false;

    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        SetPermissions();
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            allReports = await ReportService.GetAllReportsAsync();
            recentReports = allReports.OrderByDescending(r => r.ReportDate).ToList();
            allReviews = await ReviewService.GetAllReviewsAsync();

            totalReports = allReports.Count;
            openReports = allReports.Count(r => r.Status == ReportStatus.Pending || r.Status == ReportStatus.UnderReview);
            finalizedReports = allReports.Count(r => r.Status == ReportStatus.DecisionReached || r.Status == ReportStatus.Closed);
            totalReviews = allReviews.Count;
        }
        catch (Exception ex)
        {
            // Handle error - in a real app, you might want to show a toast or alert
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetPermissions()
    {
        canReviewReports = AuthService.CanUserReviewReport();
        canFinalizeReports = AuthService.CanUserFinalizeReport();
    }
}
