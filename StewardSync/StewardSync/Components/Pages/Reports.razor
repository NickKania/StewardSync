@page "/reports"
@using StewardSync.Models
@using StewardSync.Services
@using StewardSync.Services.Authentication
@inject ReportService ReportService
@inject AuthenticationService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Reports - StewardSync</PageTitle>

<div class="content fade-in">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center">
                <h1 class="display-5 fw-bold text-gradient mb-3">Incident Reports</h1>
                <p class="lead text-muted">View and manage all racing incident reports</p>
            </div>
        </div>
    </div>

<!-- Filter and Actions Section -->
    <div class="form-container form-enhanced mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="form-section-title">
                    <i class="bi bi-funnel-fill"></i>
                    Filter Reports
                </div>
                <div class="radio-group">
                    <InputRadioGroup @bind-Value="selectedFilter" Name="reportFilter">
                        <div class="radio-option">
                            <InputRadio class="form-check-input" Id="allReports" Value="@("all")" />
                            <label class="form-check-label" for="allReports">
                                <i class="bi bi-list-ul me-2"></i>
                                <strong>All Reports</strong>
                                <small class="d-block text-muted">View all incident reports</small>
                            </label>
                        </div>
                        <div class="radio-option">
                            <InputRadio class="form-check-input" Id="unfinalizedReports" Value="@("unfinalized")" />
                            <label class="form-check-label" for="unfinalizedReports">
                                <i class="bi bi-clock me-2"></i>
                                <strong>Unfinalized</strong>
                                <small class="d-block text-muted">Reports pending finalization</small>
                            </label>
                        </div>
                        <div class="radio-option">
                            <InputRadio class="form-check-input" Id="finalizedReports" Value="@("finalized")" />
                            <label class="form-check-label" for="finalizedReports">
                                <i class="bi bi-check-circle me-2"></i>
                                <strong>Finalized</strong>
                                <small class="d-block text-muted">Completed reports</small>
                            </label>
                        </div>
                    </InputRadioGroup>
                </div>
            </div>
            <div class="col-md-4 text-end">
                <button class="btn btn-primary btn-lg" @onclick="LoadReports">
                    <i class="bi bi-arrow-clockwise me-2"></i> Refresh Data
                </button>
            </div>
        </div>
    </div>

@if (isLoading)
{
    <div class="loading-overlay">
        <div class="loading-spinner"></div>
    </div>
}
else if (filteredReports.Any())
{
    <div class="form-container form-enhanced">
        <div class="form-section-title">
            <i class="bi bi-table"></i>
            Reports List (@filteredReports.Count reports)
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover enhanced-table">
                <thead>
                    <tr>
                        <th><i class="bi bi-hash me-1"></i>ID</th>
                        <th><i class="bi bi-calendar me-1"></i>Date</th>
                        <th><i class="bi bi-geo-alt me-1"></i>Event</th>
                        <th><i class="bi bi-flag me-1"></i>Race</th>
                        <th><i class="bi bi-signpost-2 me-1"></i>Turn</th>
                        <th><i class="bi bi-person-up me-1"></i>Reporting Driver</th>
                        <th><i class="bi bi-person-down me-1"></i>Reported Driver</th>
                        <th><i class="bi bi-info-circle me-1"></i>Status</th>
                        <th><i class="bi bi-clipboard-check me-1"></i>Reviews</th>
                        <th><i class="bi bi-gear me-1"></i>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in filteredReports)
                    {
                        <tr class="table-row-hover">
                            <td>
                                <span class="badge bg-primary">#@report.ReportId</span>
                            </td>
                            <td>
                                <small class="text-muted">@report.ReportDate:yyyy-MM-dd</small><br/>
                                <strong>@report.ReportDate:HH:mm</strong>
                            </td>
                            <td>
                                <div>
                                    <strong>@report.Event.Series</strong><br/>
                                    <small class="text-muted">@report.Event.TrackName</small>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info">Race @report.Race.RaceNumber</span>
                            </td>
                            <td>
                                <span class="badge bg-secondary">Turn @report.Turn</span>
                            </td>
                            <td>
                                <div class="driver-info">
                                    <span class="driver-number">@report.ReportingDriver.DriverNumber</span>
                                    <span class="driver-name">@report.ReportingDriver.DriverName</span>
                                </div>
                            </td>
                            <td>
                                <div class="driver-info">
                                    <span class="driver-number">@report.ReportedDriver.DriverNumber</span>
                                    <span class="driver-name">@report.ReportedDriver.DriverName</span>
                                </div>
                            </td>
                            <td>
                                @if (report.Status == ReportStatus.DecisionReached || report.Status == ReportStatus.Closed)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>@report.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">
                                        <i class="bi bi-clock me-1"></i>@report.Status
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">
                                    <i class="bi bi-chat-dots me-1"></i>@report.Reviews.Count
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-primary btn-sm" @onclick="() => ViewReportDetails(report.ReportId)">
                                    <i class="bi bi-eye me-1"></i> View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="form-container form-enhanced">
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h3 class="mt-3 text-muted">No Reports Found</h3>
            <p class="text-muted">No reports match the selected criteria.</p>
            <button class="btn btn-primary" @onclick="@(() => selectedFilter = "all")">
                <i class="bi bi-arrow-counterclockwise me-2"></i> Show All Reports
            </button>
        </div>
    </div>
}

<!-- Report Details Modal -->
@if (selectedReport != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content enhanced-modal">
                <div class="modal-header gradient-header">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-text me-2"></i>
                        Report #@selectedReport.ReportId Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <!-- Report Details Column -->
                        <div class="col-lg-6">
                            <div class="form-container form-enhanced">
                                <div class="form-section-title">
                                    <i class="bi bi-info-circle-fill"></i>
                                    Incident Information
                                </div>
                                
                                <div class="row g-3">
                                    <div class="col-6">
                                        <div class="info-card">
                                            <small class="text-muted d-block">Report ID</small>
                                            <strong class="text-primary">#@selectedReport.ReportId</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="info-card">
                                            <small class="text-muted d-block">Status</small>
                                            @if (selectedReport.Status == ReportStatus.DecisionReached || selectedReport.Status == ReportStatus.Closed)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle me-1"></i>@selectedReport.Status
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">
                                                    <i class="bi bi-clock me-1"></i>@selectedReport.Status
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="info-card">
                                            <small class="text-muted d-block">Date & Time</small>
                                            <strong>@selectedReport.ReportDate:yyyy-MM-dd HH:mm</strong>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="info-card">
                                            <small class="text-muted d-block">Event</small>
                                            <strong>@selectedReport.Event.Series - @selectedReport.Event.TrackName</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="info-card">
                                            <small class="text-muted d-block">Race</small>
                                            <span class="badge bg-info">Race @selectedReport.Race.RaceNumber</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="info-card">
                                            <small class="text-muted d-block">Turn</small>
                                            <span class="badge bg-secondary">Turn @selectedReport.Turn</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-container form-enhanced mt-3">
                                <div class="form-section-title">
                                    <i class="bi bi-people-fill"></i>
                                    Drivers Involved
                                </div>
                                
                                <div class="row g-3">
                                    <div class="col-12">
                                        <div class="driver-card">
                                            <small class="text-muted d-block">Reporting Driver</small>
                                            <div class="d-flex align-items-center">
                                                <span class="driver-number-large">@selectedReport.ReportingDriver.DriverNumber</span>
                                                <div>
                                                    <strong>@selectedReport.ReportingDriver.DriverName</strong>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="driver-card reported">
                                            <small class="text-muted d-block">Reported Driver</small>
                                            <div class="d-flex align-items-center">
                                                <span class="driver-number-large">@selectedReport.ReportedDriver.DriverNumber</span>
                                                <div>
                                                    <strong>@selectedReport.ReportedDriver.DriverName</strong>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Description and Reviews Column -->
                        <div class="col-lg-6">
                            <div class="form-container form-enhanced">
                                <div class="form-section-title">
                                    <i class="bi bi-file-text-fill"></i>
                                    Incident Description
                                </div>
                                @if (!string.IsNullOrEmpty(selectedReport.VideoUrl))
                                {
                                    <div class="mb-3">
                                        <a href="@selectedReport.VideoUrl" target="_blank" class="btn btn-outline-primary w-100">
                                            <i class="bi bi-play-circle me-2"></i>Watch Video Evidence
                                        </a>
                                    </div>
                                }
                                <div class="description-box">
                                    @selectedReport.Description
                                </div>
                            </div>

                            @if (selectedReport.Reviews.Any())
                            {
                                <div class="form-container form-enhanced mt-3">
                                    <div class="form-section-title">
                                        <i class="bi bi-clipboard-check-fill"></i>
                                        Steward Reviews (@selectedReport.Reviews.Count)
                                    </div>
                                    
                                    <div class="reviews-container">
                                        @foreach (var review in selectedReport.Reviews)
                                        {
                                            <div class="review-card">
                                                <div class="review-header">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <i class="bi bi-person-circle me-2"></i>
                                                            <strong>@review.User.UserName</strong>
                                                            <span class="badge bg-info ms-2">@review.User.Role.RoleName</span>
                                                        </div>
                                                        <small class="text-muted">@review.ReviewDate:yyyy-MM-dd HH:mm</small>
                                                    </div>
                                                </div>
                                                <div class="review-body">
                                                    <div class="mb-2">
                                                        <strong>Analysis:</strong>
                                                        <p class="mb-0 mt-1">@review.Analysis</p>
                                                    </div>
                                                     @if (!string.IsNullOrEmpty(review.Notes))
                                                     {
                                                         <div>
                                                             <strong>Notes:</strong>
                                                             <p class="mb-0 mt-1">@review.Notes</p>
                                                         </div>
                                                     }
                                                 </div>
                                             </div>
                                         }
                                     </div>
                                 </div>
                             }
                             else
                             {
                                 <div class="alert alert-info mt-3">
                                     <i class="bi bi-info-circle me-2"></i>
                                     <strong>No Reviews Yet</strong><br/>
                                     This report hasn't been reviewed by any stewards.
                                 </div>
                             }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">
                        <i class="bi bi-x-circle me-2"></i>Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Report> allReports = new();
    private List<Report> filteredReports = new();
    private Report? selectedReport;
    private string selectedFilter = "all";
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadReports();
    }

    protected override async Task OnParametersSetAsync()
    {
        await ApplyFilter();
    }

    private async Task LoadReports()
    {
        isLoading = true;
        try
        {
            allReports = await ReportService.GetAllReportsAsync();
            await ApplyFilter();
        }
        catch (Exception ex)
        {
            // Handle error - in a real app, you might want to show a toast or alert
            Console.WriteLine($"Error loading reports: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter()
    {
        await Task.Run(() =>
        {
            switch (selectedFilter)
            {
                case "unfinalized":
                    filteredReports = allReports.Where(r => r.Status == ReportStatus.Pending || r.Status == ReportStatus.UnderReview).ToList();
                    break;
                case "finalized":
                    filteredReports = allReports.Where(r => r.Status == ReportStatus.DecisionReached || r.Status == ReportStatus.Closed).ToList();
                    break;
                default:
                    filteredReports = allReports;
                    break;
            }
        });
    }

    private async Task ViewReportDetails(int reportId)
    {
        selectedReport = await ReportService.GetReportByIdAsync(reportId);
    }

    private void CloseModal()
    {
        selectedReport = null;
    }
}
</div>
